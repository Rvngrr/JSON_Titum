{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs the test suite after each implementation task is completed to catch regressions immediately",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest --run"
  }
}